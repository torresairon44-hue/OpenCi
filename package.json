{
  "name": "ai-chatbot",
  "version": "1.0.0",
  "description": "An AI-powered chatbot application similar to OpenAI ChatGPT",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc && node scripts/build-frontend.js",
    "build:server": "tsc",
    "start": "node dist/src/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand",
    "test:ci": "jest --ci --runInBand",
    "test:allow-empty": "jest --passWithNoTests",
    "preflight": "node scripts/preflight.js",
    "smoke:health": "node scripts/smoke-health.js",
    "smoke:deploy": "npm run preflight && npm run smoke:health",
    "seed:admin-dummy": "ts-node scripts/seed-admin-dummy.ts",
    "deploy:check": "npm run build && npm run preflight && npm test",
    "deploy:check:allow-empty-tests": "npm run build && npm run preflight && npm run test:allow-empty"
  },
  "keywords": [
    "ai",
    "chatbot",
    "openai",
    "typescript",
    "nodejs"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.3.0",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.18.0",
    "axios": "^1.3.4",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.11.2",
    "express-validator": "^7.0.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "rate-limit-redis": "^4.3.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^18.15.11",
    "@types/uuid": "^10.0.0",
    "clean-css": "^5.3.3",
    "esbuild": "^0.27.4",
    "html-minifier-terser": "^7.2.0",
    "javascript-obfuscator": "^5.3.0",
    "jest": "^29.5.0",
    "supertest": "^7.2.2",
    "terser": "^5.46.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "path-to-regexp": "0.1.13"
  }
}
