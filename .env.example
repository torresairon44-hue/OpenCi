# Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=production
HOST=localhost
BASE_URL=http://localhost:3000

# API Keys (NEVER commit real keys to version control)
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Lark (Feishu) OAuth — SP Madrid organization app credentials
# Register your app at https://open.feishu.cn/app
LARK_APP_ID=your-lark-app-id-here
LARK_APP_SECRET=your-lark-app-secret-here

# JWT Session Secret — generate a strong one (e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=generate-a-long-random-hex-string-here

# Database Configuration
DATABASE_PATH=./db/chatbot.db
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your-secure-password-here
PG_DATABASE=chatbot
PG_SSL=true
PG_SSL_REJECT_UNAUTHORIZED=false

# Security Configuration
# CORS: Allowed Origins (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Frontend obfuscation domain lock hostnames (comma-separated, no protocol/path)
DOMAIN_LOCK_HOSTS=localhost,127.0.0.1,yourdomain.com

# Rate Limiting (optional - defaults: 900000ms window, 100/30 requests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_MAX_REQUESTS=30
DISABLE_GLOBAL_RATE_LIMIT=false

# Logging Level
LOG_LEVEL=info
