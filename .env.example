# Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=production
HOST=localhost
BASE_URL=http://localhost:3000

# API Keys (NEVER commit real keys to version control)
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Lark (Feishu) OAuth — SP Madrid organization app credentials
# Register your app at https://open.feishu.cn/app
LARK_APP_ID=your-lark-app-id-here
LARK_APP_SECRET=your-lark-app-secret-here

# JWT Session Secret — generate a strong one (e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=generate-a-long-random-hex-string-here

# Database Configuration
DATABASE_PATH=./db/chatbot.db
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your-secure-password-here
PG_DATABASE=chatbot
PG_SSL=true
PG_SSL_REJECT_UNAUTHORIZED=false
ALLOW_IN_MEMORY_DB_IN_PRODUCTION=false

# Avatar storage strategy
# auto: Blob if token exists, otherwise filesystem (dev-friendly)
# blob: force Vercel Blob (durable)
# filesystem: force local filesystem (not durable in serverless)
AVATAR_STORAGE_BACKEND=auto
BLOB_READ_WRITE_TOKEN=
ALLOW_FILESYSTEM_AVATAR_STORAGE_IN_PRODUCTION=false

# Security Configuration
# CORS: Allowed Origins (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://yourdomain.com
DISABLE_CSRF_ORIGIN_CHECK=false

# Internal chatbot location scraper
ENABLE_CHATBOT_LOCATION_SCRAPER=false
INTERNAL_SCRAPER_API_KEY=replace-with-strong-internal-key
CHATBOT_LOCATION_FEED_URL=http://localhost:3000/api/internal/chatbot/location-feed
CHATBOT_LOCATION_POLL_MS=15000
CHATBOT_LOCATION_MAX_RETRIES=3
CHATBOT_LOCATION_RETRY_DELAY_MS=1200
CHATBOT_LOCATION_REQUEST_TIMEOUT_MS=8000
CHATBOT_LOCATION_STALE_THRESHOLD_MS=90000

# Frontend obfuscation domain lock hostnames (comma-separated, no protocol/path)
DOMAIN_LOCK_HOSTS=localhost,127.0.0.1,yourdomain.com

# Rate Limiting (optional - defaults: 900000ms window, 100/30 requests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_MAX_REQUESTS=30
DISABLE_GLOBAL_RATE_LIMIT=false

# Chat token-bucket limits (per identity type)
CHAT_RATE_LIMIT_AUTH_CAPACITY=12
CHAT_RATE_LIMIT_AUTH_REFILL_PER_SEC=0.5
CHAT_RATE_LIMIT_ANON_CAPACITY=8
CHAT_RATE_LIMIT_ANON_REFILL_PER_SEC=0.33
CHAT_RATE_LIMIT_IP_CAPACITY=5
CHAT_RATE_LIMIT_IP_REFILL_PER_SEC=0.25
CHAT_RATE_LIMIT_BASE_PAUSE_MS=10000

# AI provider resilience and queueing
AI_PROVIDER_FAILURE_THRESHOLD=3
AI_PROVIDER_CIRCUIT_OPEN_MS=60000
AI_MAX_CONCURRENT_REQUESTS=8
AI_MAX_QUEUED_REQUESTS=60
AI_QUEUE_WAIT_TIMEOUT_MS=15000
REDIS_URL=
CHAT_RATE_LIMIT_REDIS_PREFIX=openci:chatrl:
AI_DISTRIBUTED_INFLIGHT_KEY=openci:ai:inflight
AI_DISTRIBUTED_MAX_INFLIGHT=12
AI_DISTRIBUTED_SLOT_TTL_SEC=120
AI_DISTRIBUTED_SLOT_RETRY_MS=80
GOOGLE_TEXT_MODEL=gemini-1.5-flash

# Logging Level
LOG_LEVEL=info
